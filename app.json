{
  "expo": {
    "name": "YouTrader",
    "slug": "youtrader-pro",
    "version": "1.5.9",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/02ed40d6-5ad8-4a6d-9716-5ba40ec714c6"
    },
    "scheme": "youtrader",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.youtrader.pro",
      "usesAppleSignIn": true,
      "buildNumber": "91",
      "infoPlist": {
        "CFBundleLocalizations": [
          "en",
          "ru",
          "de",
          "fr",
          "es",
          "it",
          "uk"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "YouTrader lets you attach a screenshot of your trade to your journal.",
        "NSPhotoLibraryUsageDescription": "YouTrader lets you upload a trade screenshot from your photo library.",
        "NSPhotoLibraryAddUsageDescription": "YouTrader saves premium share cards directly to your photo library.",
        "NSMicrophoneUsageDescription": "Allow YouTrader to record audio notes for your trade journal.",
        "NSFaceIDUsageDescription": "Allow YouTrader to use Face ID for quick secure unlock.",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "package": "com.youtrader.pro",
      "versionCode": 57,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-localization",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow YouTrader to record audio notes for your trade journal."
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow YouTrader to use Face ID for quick secure unlock."
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "02ed40d6-5ad8-4a6d-9716-5ba40ec714c6"
      }
    },
    "owner": "pdvl"
  }
}
