{
  "name": "youtrader-pro",
  "version": "1.5.9",
  "private": true,
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:ios": "eas build --platform ios",
    "build:preview": "eas build --profile preview --platform ios",
    "typecheck": "tsc --noEmit",
    "test:export-rate-limit": "npx tsx scripts/export-rate-limit-qa.ts",
    "test:email-password": "npx tsx scripts/email-password-qa.ts",
    "test:usage-limits": "npx tsx scripts/usage-limits-qa.ts",
    "test:release-readiness": "npx tsx scripts/release-readiness-qa.ts",
    "market-intel": "node scripts/market-intel-worker/index.mjs all",
    "market-intel:news": "node scripts/market-intel-worker/index.mjs news",
    "market-intel:brief": "node scripts/market-intel-worker/index.mjs daily-brief",
    "market-intel:watchlist": "node scripts/market-intel-worker/index.mjs watchlist",
    "market-intel:summary": "node scripts/market-intel-worker/index.mjs summary",
    "market-intel:prop-firms": "node scripts/market-intel-worker/index.mjs prop-firms",
    "market-intel:calendar": "node scripts/market-intel-worker/index.mjs calendar",
    "market-intel:daily-brief": "node scripts/market-intel-worker/index.mjs daily-brief",
    "rag:import": "node scripts/rag/import-knowledge.mjs",
    "security:check": "node scripts/security-check.mjs",
    "security:audit": "npm audit --audit-level=high",
    "security:gitleaks": "gitleaks detect --no-git --source . --config .gitleaks.toml --redact",
    "security:gitleaks:history": "gitleaks detect --source . --config .gitleaks.toml --redact",
    "security:semgrep": "semgrep scan --config auto --severity ERROR --exclude node_modules --exclude dist --exclude ios/Pods --exclude ios/build --exclude android/build --exclude recovery-backups",
    "security:all": "npm run security:check && npm run security:audit && npm run security:gitleaks && npm run security:semgrep",
    "release:stability": "node scripts/release-stability-check.mjs",
    "translations:check": "node scripts/check-translations.mjs",
    "test:maestro": "maestro test .maestro",
    "test:maestro:launch": "maestro test .maestro/01_app_launch.yaml",
    "test:ai-safety": "npx promptfoo@latest eval -c promptfoo.config.yaml",
    "prepare:testflight": "node scripts/release-command-center/run.mjs testflight",
    "prepare:production": "node scripts/release-command-center/run.mjs production",
    "prepare:release": "node scripts/release-command-center/run.mjs release"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "2.75.0",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-asset": "~12.0.9",
    "expo-audio": "~1.1.1",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.7",
    "expo-file-system": "~19.0.23",
    "expo-image-picker": "~17.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.9",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "~14.0.7",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.3.4",
    "lucide-react-native": "^1.21.0",
    "posthog-react-native": "^4.53.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-purchases": "^9.2.8",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "js-yaml": "^4.3.0",
    "uuid": "^11.1.1"
  }
}
